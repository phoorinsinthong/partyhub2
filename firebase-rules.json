{
  "rules": {
    "rooms": {
      ".read": "auth != null",
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['host', 'status', 'createdAt']) && $roomId.length >= 4 && $roomId.length <= 6",
        "host": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 20"
        },
        "status": {
          ".validate": "newData.isString() && (newData.val() === 'waiting' || newData.val() === 'playing' || newData.val() === 'finished')"
        },
        "createdAt": {
          ".validate": "newData.isNumber() && newData.val() <= now && ((!data.exists() && newData.val() >= now - 30000) || (data.exists() && data.val() === newData.val()))"
        },
        "players": {
          "$playerName": {
            ".validate": "$playerName.length > 0 && $playerName.length <= 20",
            "name": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 20"
            },
            "isHost": {
              ".validate": "newData.isBoolean()"
            },
            "joinedAt": {
              ".validate": "newData.isNumber() && newData.val() <= now"
            },
            "avatar": {
              ".validate": "newData.isString() && newData.val().length <= 10"
            },
            "avatarColor": {
              ".validate": "newData.isString() && newData.val().length <= 20"
            },
            "online": {
              ".validate": "newData.isBoolean()"
            },
            "lastSeen": {
              ".validate": "newData.isNumber() || newData.val() === null"
            },
            "uid": {
              ".validate": "newData.isString() && newData.val() === auth.uid"
            }
          }
        },
        "scoreboard": {
          "$playerName": {
            ".validate": "$playerName.length <= 20",
            "wins": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 9999"
            },
            "games": {
              "$gameName": {
                ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 9999"
              }
            }
          }
        },
        "gameData": {
          ".validate": true
        },
        "drawingStrokes": {
          ".validate": true
        },
        "currentGame": {
          ".validate": "newData.isString() && newData.val().length <= 30"
        },
        "hostDisconnectedAt": {
          ".validate": "newData.isNumber() || newData.val() === null"
        }
      }
    }
  }
}
